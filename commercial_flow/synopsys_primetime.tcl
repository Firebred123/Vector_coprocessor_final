# synopsys_primetime.tcl - PrimeTime Static Timing Analysis (STA) Script
# Usage: pt_shell -f commercial_flow/synopsys_primetime.tcl

# Create report directory
sh mkdir -p reports_pt

# =========================================================================
# 1. Read Design Libraries and Mapped Verilog Netlist
# =========================================================================
# Replace with the path to your university's PDK directory
set PDK_PATH "/path/to/your/commercial/pdk"

set search_path [concat $search_path [list \
    "." \
    "${PDK_PATH}/libs/db" \
]]

# Define cell libraries (.db format)
set target_library "sky130_fd_sc_hd__tt_025C_1v80.db"
set link_library [concat "*" $target_library]

# Read synthesized netlist (generated by Design Compiler or Genus)
read_verilog outputs_dc/vector_coprocessor.synth.v

# Link design top level
link_design vector_coprocessor

# =========================================================================
# 2. Read Timing Constraints (SDC)
# =========================================================================
read_sdc commercial_flow/coprocessor_commercial.sdc

# =========================================================================
# 3. Read Parasitics (Optional - used post-PnR/Layout)
# =========================================================================
# In a post-layout flow, read SPEF (Standard Parasitic Exchange Format)
# read_parasitics -format spef outputs_pnr/vector_coprocessor.spef

# =========================================================================
# 4. Analyze Timing and Export Reports
# =========================================================================
# Validate constraints and timing checks are complete
check_timing > reports_pt/check_timing.rpt

# Generate timing reports
report_timing -delay_type max -max_paths 20 -format full > reports_pt/setup.rpt
report_timing -delay_type min -max_paths 20 -format full > reports_pt/hold.rpt
report_analysis_coverage > reports_pt/coverage.rpt
report_constraint -all_violators > reports_pt/violators.rpt

exit
